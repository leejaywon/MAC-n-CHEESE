# Template — copy to .env and fill in. The real .env is gitignored; never commit it.
#   cp .env.example .env   then edit .env
#
# Enables the optional `--best` model/retrieval layer (reviewer/pipeline.py:_judgment_enabled).
# Without a key, set RALPH_BEST_RETRIEVAL=1 to enable the same layer key-free.
OPENAI_API_KEY=

# If your hackathon key is a pre-funded OpenAI-compatible proxy, it also needs a base URL.
# NOTE: not consumed by the code yet — wiring required before this takes effect.
# OPENAI_BASE_URL=
