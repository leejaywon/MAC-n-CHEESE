DEFAULT_METRIC_FIELDS = (
    "val_bpb",
    "score",
    "accuracy",
    "loss",
    "perplexity",
    "mfu_percent",
    "peak_vram_mb",
    "elapsed_seconds",
    "training_seconds",
    "total_seconds",
    "num_params_M",
    "total_tokens_M",
)
