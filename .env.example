# Required for the review committee
OPENAI_API_KEY=

# Committee model — required whenever the committee runs
# Cost ↑ quality: gpt-5.6-sol | gpt-5.6-terra | gpt-5.6-luna | gpt-5.5
# Cost ↓:         gpt-5.4-mini | gpt-5-mini | gpt-5.4-nano
OPENAI_MODEL=gpt-5.6-sol

# Panel size: N reviewers + area chair (N>=2). 1 = single-reviewer mode (skips Area Chair).
REVIEWER_PANEL=3

# Reasoning effort (reasoning models): medium | high | xhigh
REVIEWER_COMMITTEE_EFFORT=xhigh

# Per-request HTTP timeout in seconds (reasoning + high can need 1200+)
REVIEWER_COMMITTEE_TIMEOUT=1200
