# Template — copy to .env and fill in. The real .env is gitignored; never commit it.
#   cp .env.example .env   then edit .env
#
# The scientific committee and prior-art retrieval run by default, on top of the
# deterministic audit. Without a key, REVIEWER_BEST_RETRIEVAL=1 enables retrieval
# only; the committee review requires an OpenAI-compatible API key. Pass
# run_review.py --deterministic to skip both (offline, reproducible, no API cost).
OPENAI_API_KEY=

# If your key targets an OpenAI-compatible proxy, configure its API root.
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Maximum sanitized paper characters supplied to the committee. High-value sections
# (Abstract, Method, Experiments, Limitations, References) are retained first.
# REVIEWER_BEST_MAX_CHARS=60000

# Three specialist calls run concurrently before the area-chair meta-review.
# REVIEWER_COMMITTEE_WORKERS=3
# REVIEWER_COMMITTEE_TIMEOUT=60

# Reasoning effort for the committee's model calls (reasoning models like gpt-5.x):
# minimal | low | medium | high. Unset = the model's own default; a model that
# does not support it ignores the setting (the request auto-drops it).
# REVIEWER_COMMITTEE_EFFORT=high

# Enable retrieval-only committee grounding without a model key.
# REVIEWER_BEST_RETRIEVAL=1
