# Template — copy to .env and fill in. The real .env is gitignored; never commit it.
#   cp .env.example .env   then edit .env
#
# Enables the `--best` scientific committee and prior-art retrieval.
# Without a key, RALPH_BEST_RETRIEVAL=1 enables retrieval only; committee review
# requires an OpenAI-compatible API key.
OPENAI_API_KEY=

# If your key targets an OpenAI-compatible proxy, configure its API root.
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Maximum sanitized paper characters supplied to best mode. High-value sections
# (Abstract, Method, Experiments, Limitations, References) are retained first.
# RALPH_BEST_MAX_CHARS=60000

# Three specialist calls run concurrently before the area-chair meta-review.
# RALPH_COMMITTEE_WORKERS=3
# RALPH_COMMITTEE_TIMEOUT=60

# Enable retrieval-only best mode without a model key.
# RALPH_BEST_RETRIEVAL=1
