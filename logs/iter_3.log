        text = """# Results

| Trial | accuracy | loss |
|---|---:|---:|
| baseline | 70 | 2.0 |
| candidate | 75 | 1.5 |

The relative improvement is 7.14%.
"""
        with tempfile.TemporaryDirectory() as directory:
            result = check_arithmetic(_parse(text, Path(directory)))

        self.assertEqual(result["traces"], [])
        self.assertEqual(result["findings"], [])

