# Required for the review committee
OPENAI_API_KEY=

# Committee model — required whenever the committee runs
OPENAI_MODEL=gpt-5.6-sol

# Panel size: N reviewers read the full paper, an area chair synthesizes (N>=2).
# 1 = single-reviewer mode (cheapest; skips the area chair).
REVIEWER_PANEL=3

REVIEWER_COMMITTEE_EFFORT=high
REVIEWER_COMMITTEE_TIMEOUT=600
