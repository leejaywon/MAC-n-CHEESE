+        encoding="utf-8",
+    )
+    print(f"generated {len(CASES)} papers ({sum(bool(case.replacement) for case in CASES)} corrupted, 2 clean)")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
